---
interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 20, class: className = '', strokeWidth = 1.5 } = Astro.props;

const icons: Record<string, string> = {
  // Navigation / service icons
  shop: `<path d="M4 8h12l-2 9H6L4 8z" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 8V6a2 2 0 014 0v2" stroke-linecap="round" stroke-linejoin="round"/>`,

  migration: `<path d="M3 7h11M10 4l4 3-4 3" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 13H6M10 16l-4-3 4-3" stroke-linecap="round" stroke-linejoin="round"/>`,

  code: `<path d="M6 8L2 10l4 2M14 8l4 2-4 2M11.5 5.5l-3 9" stroke-linecap="round" stroke-linejoin="round"/>`,

  // Feature icons
  zap: `<path d="M11.5 2L4 11h7.5L8 18l9-10h-7l2-6z" stroke-linecap="round" stroke-linejoin="round"/>`,

  shield: `<path d="M10 2L3 5.5v4.5c0 3.9 3 7.5 7 8.5 4-1 7-4.6 7-8.5V5.5L10 2z" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`,

  mobile: `<rect x="5.5" y="2" width="9" height="16" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="15.5" r="0.75" fill="currentColor" stroke="none"/>`,

  globe: `<circle cx="10" cy="10" r="8"/><path d="M2 10h16" stroke-linecap="round"/><path d="M10 2c-2.5 2-4 4.8-4 8s1.5 6 4 8M10 2c2.5 2 4 4.8 4 8s-1.5 6-4 8" stroke-linecap="round" stroke-linejoin="round"/>`,

  grid: `<rect x="2.5" y="2.5" width="6" height="6" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="11.5" y="2.5" width="6" height="6" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="2.5" y="11.5" width="6" height="6" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="11.5" y="11.5" width="6" height="6" rx="1" stroke-linecap="round" stroke-linejoin="round"/>`,

  chart: `<path d="M4 16.5V11M8.5 16.5V7M13 16.5V4M4 16.5h12" stroke-linecap="round" stroke-linejoin="round"/>`,

  // "Why us" / values icons
  target: `<path d="M5 15L15 5M10 5h5v5" stroke-linecap="round" stroke-linejoin="round"/>`,

  eye: `<path d="M1.5 10s3.5-6 8.5-6 8.5 6 8.5 6-3.5 6-8.5 6-8.5-6-8.5-6z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="10" r="2.5" stroke-linecap="round"/>`,

  layers: `<path d="M2 7l8-4 8 4-8 4-8-4z" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 11.5l8 4 8-4" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 16l8 4 8-4" stroke-linecap="round" stroke-linejoin="round"/>`,

  users: `<path d="M13 17v-1a4 4 0 00-6-3.46M13 17H7M10 9a3 3 0 100-6 3 3 0 000 6z" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 17v-1a3 3 0 00-2-2.83M14.5 4.5a3 3 0 010 5" stroke-linecap="round" stroke-linejoin="round"/>`,

  // Utility
  check: `<path d="M4 10l4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/>`,

  arrow: `<path d="M3 10h14M11 4l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---

<svg
  width={size}
  height={size}
  viewBox="0 0 20 20"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  class={className}
  aria-hidden="true"
>
  <Fragment set:html={icons[name] ?? ''} />
</svg>
