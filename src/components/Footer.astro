---
import { SITE } from '@/config/site';
const year = new Date().getFullYear();
---

<footer class="bg-[#0C0C0F] text-[#88888F]">
  <!-- Main footer -->
  <div class="container pt-16 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10 pb-12 border-b border-[#1C1C25]">

      <!-- Brand column -->
      <div>
        <a href="/" class="flex items-center gap-2.5 mb-5 group">
          <div class="w-8 h-8 rounded-lg bg-white/8 border border-white/10 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M3 4h14L10 16 3 4z" fill="white"/>
            </svg>
          </div>
          <span class="font-semibold text-[15px] text-white tracking-[-0.01em]">{SITE.name}</span>
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-xs">
          Shopify-Experten für ambitionierte E-Commerce-Unternehmen. Shops, die wirklich verkaufen.
        </p>
        <div class="flex gap-2">
          <a
            href={SITE.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-[#62626E] hover:text-white hover:border-white/20 transition-colors"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href={SITE.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-[#62626E] hover:text-white hover:border-white/20 transition-colors"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href={SITE.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-[#62626E] hover:text-white hover:border-white/20 transition-colors"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white text-[13px] font-semibold mb-5 tracking-[-0.01em]">Leistungen</h3>
        <ul class="space-y-3 text-[13.5px]">
          <li><a href="/leistungen/shopify-shop-erstellen" class="hover:text-white transition-colors">Shopify Shop erstellen</a></li>
          <li><a href="/leistungen/shopify-migration" class="hover:text-white transition-colors">Shopify Migration</a></li>
          <li><a href="/leistungen/individuelle-entwicklung" class="hover:text-white transition-colors">Individuelle Entwicklung</a></li>
          <li><a href="/leistungen" class="hover:text-white transition-colors">Alle Leistungen</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white text-[13px] font-semibold mb-5 tracking-[-0.01em]">Unternehmen</h3>
        <ul class="space-y-3 text-[13.5px]">
          <li><a href="/ueber-uns" class="hover:text-white transition-colors">Über uns</a></li>
          <li><a href="/referenzen" class="hover:text-white transition-colors">Referenzen</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/projekt-starten" class="hover:text-white transition-colors">Projekt starten</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
          <li><a href="/karriere" class="hover:text-white transition-colors">Karriere</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white text-[13px] font-semibold mb-5 tracking-[-0.01em]">Kontakt</h3>
        <ul class="space-y-3 text-[13.5px]">
          <li>
            <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors">{SITE.email}</a>
          </li>
          <li>
            <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="hover:text-white transition-colors">{SITE.phone}</a>
          </li>
          <li class="text-[13px] leading-relaxed text-[#62626E]">
            {SITE.address.street}<br />
            {SITE.address.zip} {SITE.address.city}
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 text-[13px]">
      <p>© {year} {SITE.name}. Alle Rechte vorbehalten.</p>
      <div class="flex items-center gap-5">
        <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
        <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
        <a href="/agb" class="hover:text-white transition-colors">AGB</a>
      </div>
    </div>
  </div>
</footer>
