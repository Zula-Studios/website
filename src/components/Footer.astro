---
import { SITE } from '@/config/site';
const year = new Date().getFullYear();
---

<footer class="bg-[#0C0C0F] text-[#88888F]">
  <div class="container pt-16 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr_1fr_1fr] gap-10 pb-12 border-b border-[#1C1C25]">

      <!-- Brand column -->
      <div>
        <a href="/" class="flex items-center gap-2.5 mb-5 group">
          <div class="w-8 h-8 rounded-lg bg-white/8 border border-white/10 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M3 4h14L10 16 3 4z" fill="white"/>
            </svg>
          </div>
          <span class="font-semibold text-[15px] text-white tracking-[-0.01em]">{SITE.name}</span>
        </a>

        <!-- Keyword-reiche Beschreibung -->
        <p class="text-sm leading-relaxed mb-5 max-w-xs">
          Shopify Agentur aus Hamburg — spezialisiert auf Shopify Shop-Erstellung, Migrationen und individuelle Entwicklung mit Laravel & Astro.js. Für E-Commerce-Unternehmen, die wachsen wollen.
        </p>

        <!-- NAP (Name, Address, Phone) – wichtig für lokales SEO -->
        <address class="not-italic text-[13px] text-[#62626E] leading-relaxed mb-5">
          <span class="block text-[#88888F] font-medium">{SITE.name}</span>
          <span class="block">{SITE.address.street}</span>
          <span class="block">{SITE.address.zip} {SITE.address.city}</span>
          <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors mt-1 block">{SITE.email}</a>
        </address>

        <!-- Social links -->
        <div class="flex gap-2">
          {SITE.social.linkedin && (
            <a
              href={SITE.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Zula Studios auf LinkedIn"
              class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-[#62626E] hover:text-white hover:border-white/20 transition-colors"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          <a
            href={SITE.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Zula Studios auf GitHub"
            class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-[#62626E] hover:text-white hover:border-white/20 transition-colors"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Leistungen nav -->
      <nav aria-label="Leistungen Navigation">
        <h3 class="text-white text-[13px] font-semibold mb-5 tracking-[-0.01em]">Leistungen</h3>
        <ul class="space-y-3 text-[13.5px]">
          <li><a href="/leistungen/shopify-shop-erstellen" class="hover:text-white transition-colors">Shopify Shop erstellen</a></li>
          <li><a href="/leistungen/shopify-migration" class="hover:text-white transition-colors">Shopify Migration</a></li>
          <li><a href="/leistungen/individuelle-entwicklung" class="hover:text-white transition-colors">Laravel & Astro.js Entwicklung</a></li>
          <li><a href="/leistungen/individuelle-entwicklung" class="hover:text-white transition-colors">Headless Commerce</a></li>
          <li><a href="/leistungen" class="hover:text-white transition-colors">Alle Leistungen</a></li>
        </ul>
      </nav>

      <!-- Unternehmen nav -->
      <nav aria-label="Unternehmen Navigation">
        <h3 class="text-white text-[13px] font-semibold mb-5 tracking-[-0.01em]">Unternehmen</h3>
        <ul class="space-y-3 text-[13.5px]">
          <li><a href="/ueber-uns" class="hover:text-white transition-colors">Über uns</a></li>
          <li><a href="/referenzen" class="hover:text-white transition-colors">Referenzen & Projekte</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog & Ratgeber</a></li>
          <li><a href="/projekt-starten" class="hover:text-white transition-colors">Projekt starten</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </nav>

      <!-- Standort -->
      <div>
        <h3 class="text-white text-[13px] font-semibold mb-5 tracking-[-0.01em]">Standort</h3>
        <p class="text-[13px] text-[#62626E] leading-relaxed">
          Shopify Agentur Hamburg<br />
          & Henstedt-Ulzburg<br />
          <span class="text-[#3E3E4A]">Bundesweit tätig</span>
        </p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 pt-6 text-[12.5px]">
      <p>© {year} {SITE.name} – Shopify Agentur Hamburg. Alle Rechte vorbehalten.</p>
      <div class="flex items-center gap-5 text-[#3E3E4A]">
        <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
        <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
      </div>
    </div>
  </div>
</footer>
