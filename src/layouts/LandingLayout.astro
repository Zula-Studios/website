---
/**
 * Stripped landing page layout for ad campaigns.
 * No main navigation – only logo + phone CTA at top.
 * Maximises conversion focus.
 */
import SEO from '@/components/SEO.astro';
import { SITE } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0C0C0F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap"
      />
    </noscript>
    <SEO {...props} />
    <style is:global>
      :root {
        --ink: #0C0C0F; --ink-muted: #62626E; --ink-subtle: #AEAEB5;
        --surface-warm: #FAFAF8; --border: #EBEBEF;
        --accent: #0284C7; --accent-light: #F0F9FF;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { font-feature-settings: 'cv11' on, 'ss01' on; }
      body { font-family: 'Inter', system-ui, sans-serif; color: var(--ink); background: #fff; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
      ::selection { background: #BAE6FD; color: #0C4A6E; }
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-thumb { background: #D4D4D9; border-radius: 10px; }
      :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px; }
      .container { max-width: 1240px; margin: 0 auto; padding: 0 1.25rem; }
      @media (min-width: 640px) { .container { padding: 0 2rem; } }
      @media (min-width: 1024px) { .container { padding: 0 2.5rem; } }
      .label { display: inline-block; font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-subtle); }
      .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 0.625rem; transition: all 0.15s ease; cursor: pointer; white-space: nowrap; text-decoration: none; }
      .btn:active { transform: scale(0.97); }
      .btn-primary { background: var(--ink); color: #fff; }
      .btn-primary:hover { background: #1C1C25; }
      .btn-accent { background: var(--accent); color: #fff; }
      .btn-accent:hover { background: #0369A1; }
      .btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--border); }
      .btn-outline:hover { border-color: #D4D4D9; background: var(--surface-warm); }
      [data-reveal] { opacity: 0; transform: translateY(16px); transition: opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1); }
      [data-reveal].visible { opacity: 1; transform: none; }
      [data-delay="1"] { transition-delay: 0.08s; }
      [data-delay="2"] { transition-delay: 0.16s; }
      [data-delay="3"] { transition-delay: 0.24s; }
      [data-delay="4"] { transition-delay: 0.32s; }
    </style>
  </head>
  <body>
    <!-- Minimal conversion header -->
    <header class="sticky top-0 z-50 bg-white/94 backdrop-blur-md border-b border-[#EBEBEF]">
      <div class="container flex items-center justify-between h-[60px]">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-7 h-7 rounded-lg bg-[#0C0C0F] flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
              <path d="M3 4h14L10 16 3 4z" fill="white"/>
            </svg>
          </div>
          <span class="font-semibold text-[14px] text-[#0C0C0F] tracking-[-0.01em]">{SITE.name}</span>
        </a>
        <div class="flex items-center gap-3">
          <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="hidden sm:flex items-center gap-2 text-[13px] font-medium text-[#62626E] hover:text-[#0C0C0F] transition-colors">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V17a2 2 0 01-2 2h-1C9.716 19 3 12.284 3 4V3z" fill="currentColor"/>
            </svg>
            {SITE.phone}
          </a>
          <a href="/projekt-starten" class="btn btn-primary text-[13px] py-2 px-4">Jetzt anfragen</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Minimal footer for landing pages -->
    <footer class="bg-[#0C0C0F] py-8">
      <div class="container flex flex-col sm:flex-row items-center justify-between gap-4 text-[12.5px] text-[#62626E]">
        <a href="/" class="text-white font-semibold">{SITE.name}</a>
        <div class="flex gap-5">
          <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
          <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
        </div>
      </div>
    </footer>

    <!-- Sticky bottom CTA (mobile) -->
    <div class="fixed bottom-0 left-0 right-0 z-40 sm:hidden bg-white border-t border-[#EBEBEF] p-3 flex gap-2">
      <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="btn btn-outline flex-1 justify-center py-3 text-[13px]">
        Anrufen
      </a>
      <a href="/projekt-starten" class="btn btn-primary flex-1 justify-center py-3 text-[13px]">
        Jetzt anfragen
      </a>
    </div>

    <script>
      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach(el => obs.observe(el));
    </script>
  </body>
</html>
