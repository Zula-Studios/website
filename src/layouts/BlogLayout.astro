---
import BaseLayout from './BaseLayout.astro';
import { SITE } from '@/config/site';

interface Props {
  title: string;
  description: string;
  publishedDate: string;
  modifiedDate?: string;
  author?: string;
  category?: string;
  tags?: string[];
  ogImage?: string;
  readingTime?: number;
  slug: string;
}

const {
  title,
  description,
  publishedDate,
  modifiedDate,
  author = 'Zula Studios Team',
  category,
  tags = [],
  ogImage,
  readingTime,
  slug,
} = Astro.props;

const breadcrumbs = [
  { name: 'Startseite', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: title, url: `/blog/${slug}` },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author, url: SITE.url },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: new URL(SITE.logo, SITE.url).toString() },
  },
  datePublished: publishedDate,
  dateModified: modifiedDate ?? publishedDate,
  image: ogImage ? new URL(ogImage, SITE.url).toString() : new URL(SITE.ogImage, SITE.url).toString(),
  url: new URL(`/blog/${slug}`, SITE.url).toString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(`/blog/${slug}`, SITE.url).toString() },
};

const formattedDate = new Date(publishedDate).toLocaleDateString('de-DE', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  publishedDate={publishedDate}
  modifiedDate={modifiedDate}
  author={author}
  schema={articleSchema}
  breadcrumbs={breadcrumbs}
>
  <!-- Article header -->
  <div class="bg-[#FAFAF8] border-b border-[#EBEBEF] py-14 lg:py-20">
    <div class="container max-w-2xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[#AEAEB5] mb-8 flex-wrap">
        <a href="/" class="hover:text-[#0C0C0F] transition-colors">Startseite</a>
        <span>/</span>
        <a href="/blog" class="hover:text-[#0C0C0F] transition-colors">Blog</a>
        <span>/</span>
        <span class="text-[#62626E] truncate">{title}</span>
      </nav>

      {category && (
        <span class="inline-block text-[10.5px] font-bold uppercase tracking-wider text-accent-600 bg-accent-50 px-2.5 py-1 rounded-md mb-5">
          {category}
        </span>
      )}

      <h1 class="font-bold text-[#0C0C0F] tracking-[-0.03em] mb-4 leading-tight" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        {title}
      </h1>

      <p class="text-[#62626E] text-base lg:text-lg leading-relaxed mb-7">{description}</p>

      <div class="flex flex-wrap items-center gap-4 text-xs text-[#AEAEB5]">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-lg bg-[#0C0C0F] text-white text-[10px] font-bold flex items-center justify-center">
            {author.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
          </div>
          <span class="font-medium text-[#62626E]">{author}</span>
        </div>
        <span>·</span>
        <time datetime={publishedDate}>{formattedDate}</time>
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} Min. Lesezeit</span>
          </>
        )}
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-5">
          {tags.map(tag => (
            <span class="text-[11px] bg-[#EBEBEF] text-[#62626E] px-2.5 py-1 rounded-lg">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Article body -->
  <article class="py-14 lg:py-20">
    <div class="container max-w-2xl">
      <div class="prose prose-gray max-w-none
        prose-headings:font-bold prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-[#0C0C0F]
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-[#0C0C0F]
        prose-p:text-[#44444F] prose-p:leading-relaxed prose-p:text-[15.5px]
        prose-a:text-accent-600 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-[#0C0C0F] prose-strong:font-semibold
        prose-ul:text-[#44444F] prose-ol:text-[#44444F]
        prose-li:my-1.5 prose-li:text-[15.5px]
        prose-table:text-sm prose-th:text-[#0C0C0F]
      ">
        <slot />
      </div>
    </div>
  </article>

  <!-- Back to blog -->
  <div class="py-12 border-t border-[#EBEBEF]">
    <div class="container max-w-2xl">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-[#62626E] hover:text-[#0C0C0F] transition-colors">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
          <path d="M13 7H1M6 2L1 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Zurück zum Blog
      </a>
    </div>
  </div>
</BaseLayout>
