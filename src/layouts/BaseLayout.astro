---
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
  publishedDate?: string;
  modifiedDate?: string;
  author?: string;
  breadcrumbs?: { name: string; url: string }[];
  darkHero?: boolean;
}

const { darkHero = false, ...props } = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0C0C0F" />

    <!-- ── Font resource hints (non-blocking) ────────────────────────────────
         dns-prefetch is the fallback for browsers that don't support preconnect.
         preconnect initiates the TLS handshake to Google's servers early so the
         font request fires immediately without a cold DNS+TCP+TLS round-trip.
    ──────────────────────────────────────────────────────────────────────── -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- ── Async font loading (loadCSS technique) ────────────────────────────
         Using rel="preload" with onload avoids render-blocking font CSS.
         Only the weights actually used in the design are requested.
         font-display:swap is included via the &display=swap parameter.
         <noscript> ensures the font still loads when JS is disabled.
    ──────────────────────────────────────────────────────────────────────── -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap"
      />
    </noscript>
    <SEO {...props} />
    <style is:global>
      /* ── Design Tokens ── */
      :root {
        --ink: #0C0C0F;
        --ink-muted: #62626E;
        --ink-subtle: #AEAEB5;
        --surface-warm: #FAFAF8;
        --border: #EBEBEF;
        --accent: #0284C7;
        --accent-light: #F0F9FF;
        --radius: 0.75rem;
        --transition: cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* ── Base ── */
      *, *::before, *::after { box-sizing: border-box; }

      html { font-feature-settings: 'cv11' on, 'ss01' on, 'cv01' on, 'cv08' on; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        color: var(--ink);
        background: #ffffff;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      /* ── Selection ── */
      ::selection {
        background: #BAE6FD;
        color: #0C4A6E;
      }

      /* ── Scrollbar ── */
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #D4D4D9; border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #AEAEB5; }

      /* ── Focus ── */
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 4px;
      }

      /* ── Container ── */
      .container {
        max-width: 1240px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 1.25rem;
        padding-right: 1.25rem;
      }
      @media (min-width: 640px) {
        .container { padding-left: 2rem; padding-right: 2rem; }
      }
      @media (min-width: 1024px) {
        .container { padding-left: 2.5rem; padding-right: 2.5rem; }
      }

      /* ── Section Label ── */
      .label {
        display: inline-block;
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-subtle);
      }

      /* ── Scroll Progress Bar ── */
      #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0%;
        background: var(--accent);
        z-index: 9999;
        transition: width 80ms linear;
        pointer-events: none;
      }

      /* ── Reveal Animations ── */
      [data-reveal] {
        opacity: 0;
        transform: translateY(18px);
        transition:
          opacity 0.65s var(--transition),
          transform 0.65s var(--transition);
        will-change: opacity, transform;
      }
      [data-reveal="fade"] { transform: none; }
      [data-reveal="left"] { transform: translateX(-18px); }
      [data-reveal="scale"] { transform: scale(0.97); }
      [data-reveal].visible {
        opacity: 1;
        transform: none;
      }
      [data-delay="1"] { transition-delay: 0.08s; }
      [data-delay="2"] { transition-delay: 0.16s; }
      [data-delay="3"] { transition-delay: 0.24s; }
      [data-delay="4"] { transition-delay: 0.32s; }
      [data-delay="5"] { transition-delay: 0.42s; }
      [data-delay="6"] { transition-delay: 0.52s; }

      /* ── Marquee ── */
      .marquee-track {
        display: flex;
        width: max-content;
        animation: marquee 32s linear infinite;
      }
      .marquee-track:hover { animation-play-state: paused; }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      /* ── Smooth details/summary ── */
      details > summary { list-style: none; cursor: pointer; }
      details > summary::-webkit-details-marker { display: none; }

      /* ── Button base ── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        padding: 0.75rem 1.5rem;
        border-radius: 0.625rem;
        transition: all 0.15s ease;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
      }
      .btn:active { transform: scale(0.97); }
      .btn-primary {
        background: var(--ink);
        color: #ffffff;
      }
      .btn-primary:hover { background: #1C1C25; }
      .btn-ghost {
        background: transparent;
        color: rgba(255,255,255,0.75);
        border: 1px solid rgba(255,255,255,0.15);
      }
      .btn-ghost:hover {
        background: rgba(255,255,255,0.08);
        color: #ffffff;
      }
      .btn-outline {
        background: transparent;
        color: var(--ink);
        border: 1.5px solid var(--border);
      }
      .btn-outline:hover { border-color: #D4D4D9; background: var(--surface-warm); }
      .btn-accent {
        background: var(--accent);
        color: #ffffff;
      }
      .btn-accent:hover { background: #0369A1; }
    </style>
  </head>
  <body data-hero={darkHero ? 'dark' : 'light'}>
    <div id="scroll-progress"></div>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      // ── Scroll Progress ──
      const progressBar = document.getElementById('scroll-progress');
      function updateProgress() {
        const scrolled = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
        if (progressBar) progressBar.style.width = (scrolled * 100) + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });

      // ── Reveal Animations ──
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

      // ── Header scroll behavior ──
      const header = document.getElementById('site-header');
      const heroDark = document.body.dataset.hero === 'dark';

      function updateHeader() {
        if (!header) return;
        const scrolled = window.scrollY > 60;
        header.classList.toggle('header-scrolled', scrolled);
        if (heroDark) {
          header.classList.toggle('header-on-dark', !scrolled);
        }
      }

      window.addEventListener('scroll', updateHeader, { passive: true });
      updateHeader();
    </script>
  </body>
</html>
