---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';
import Icon from '@/components/Icon.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Projekt starten – Zula Studios',
  url: `${SITE.url}/projekt-starten`,
  mainEntity: {
    '@type': 'Organization',
    name: SITE.name,
    telephone: SITE.phone,
    email: SITE.email,
  },
};

const services = [
  { value: 'shopify-shop',             label: 'Shopify Shop',       desc: 'Neuer Shop von Grund auf',  iconName: 'shop'      },
  { value: 'shopify-migration',        label: 'Migration',          desc: 'Wechsel zu Shopify',        iconName: 'migration' },
  { value: 'individuelle-entwicklung', label: 'Custom App',         desc: 'Apps & Integrationen',      iconName: 'code'      },
  { value: 'optimierung',              label: 'Optimierung',        desc: 'Performance & Conversion',  iconName: 'zap'       },
  { value: 'beratung',                 label: 'Beratung / Audit',   desc: 'Strategie & Analyse',       iconName: 'eye'       },
  { value: 'sonstiges',                label: 'Sonstiges',          desc: 'Anderes Vorhaben',          iconName: 'layers'    },
];

const budgets = [
  { value: 'bis-5000',   label: 'Bis 5.000 €'         },
  { value: '5k-15k',     label: '5.000 – 15.000 €'    },
  { value: '15k-30k',    label: '15.000 – 30.000 €'   },
  { value: '30k-plus',   label: '30.000+ €'            },
  { value: 'noch-offen', label: 'Noch nicht bekannt'   },
];

const timelines = [
  { value: 'sofort',     label: 'So bald wie möglich' },
  { value: '1-3-monate', label: 'In 1–3 Monaten'      },
  { value: '3-plus',     label: 'In 3+ Monaten'       },
  { value: 'unklar',     label: 'Noch unklar'         },
];

const trust = [
  'Antwort innerhalb von 24 Std.',
  'Erstes Konzept kostenlos',
  'Kein Verkaufsdruck',
  'DSGVO-konform',
];
---

<BaseLayout
  title="Projekt starten – Kostenloses Erstgespräch"
  description="Starten Sie Ihr Shopify-Projekt. Wir melden uns innerhalb von 24 Stunden mit einem ersten Konzept. Kostenlos und unverbindlich."
  schema={schema}
  darkHero={true}
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Projekt starten', url: '/projekt-starten' }]}
>

  <!-- HERO -->
  <section class="bg-[#0C0C0F] pt-20 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[500px]" style="background: radial-gradient(circle at 75% 20%, rgba(56,189,248,0.15), transparent 60%);"></div>
    <div class="container relative z-10">
      <nav class="flex items-center gap-2 text-xs text-[#9898A0] mb-12">
        <a href="/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <span class="text-white font-medium">Projekt starten</span>
      </nav>
      <p class="text-[#9898A0] text-[11px] font-semibold tracking-[0.2em] uppercase mb-5 flex items-center gap-3">
        <span class="w-5 h-px bg-[#2E2E3A]"></span>
        Kostenloses Erstgespräch
      </p>
      <h1 class="font-bold text-white tracking-[-0.04em]" style="font-size: clamp(2.75rem, 7vw, 5.5rem); line-height: 0.93; animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s both">
        Starten wir<br/>
        <span class="font-light italic text-white/45">Ihr Projekt.</span>
      </h1>
    </div>
  </section>

  <!-- MAIN -->
  <section class="bg-white py-16 lg:py-24">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-20 items-start">

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-28 space-y-6" data-reveal>
          <div>
            <p class="label mb-5">Direkter Kontakt</p>
            <div class="space-y-3">
              <a href={`mailto:${SITE.email}`} class="flex items-center gap-3 group">
                <div class="w-10 h-10 rounded-xl bg-[#F5F5F8] group-hover:bg-accent-50 flex items-center justify-center transition-colors shrink-0">
                  <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[#88888F] group-hover:text-accent-600 transition-colors">
                    <path d="M3 7l7 5 7-5M3 6h14a1 1 0 011 1v8a1 1 0 01-1 1H3a1 1 0 01-1-1V7a1 1 0 011-1z" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div>
                  <div class="text-[10px] label mb-0.5">E-Mail</div>
                  <div class="text-sm font-semibold text-[#0C0C0F] group-hover:text-accent-600 transition-colors">{SITE.email}</div>
                </div>
              </a>
              <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="flex items-center gap-3 group">
                <div class="w-10 h-10 rounded-xl bg-[#F5F5F8] group-hover:bg-accent-50 flex items-center justify-center transition-colors shrink-0">
                  <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="text-[#88888F] group-hover:text-accent-600 transition-colors">
                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V17a2 2 0 01-2 2h-1C9.716 19 3 12.284 3 4V3z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-[10px] label mb-0.5">Telefon</div>
                  <div class="text-sm font-semibold text-[#0C0C0F] group-hover:text-accent-600 transition-colors">{SITE.phone}</div>
                </div>
              </a>
            </div>
          </div>

          <div class="rounded-2xl bg-[#FAFAF8] border border-[#EBEBEF] p-5">
            <p class="text-[10px] label mb-3">Erreichbarkeit</p>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-[#62626E]">Mo – Fr</span>
                <span class="font-medium text-[#0C0C0F]">09:00 – 18:00</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#62626E]">Sa – So</span>
                <span class="text-[#AEAEB5]">Auf Anfrage</span>
              </div>
              <div class="pt-2.5 border-t border-[#EBEBEF] flex items-center gap-2 text-emerald-600 text-xs font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse shrink-0"></span>
                Antwort innerhalb von 24 Stunden
              </div>
            </div>
          </div>

          <div class="space-y-2.5">
            {trust.map(item => (
              <div class="flex items-center gap-2.5 text-sm text-[#62626E]">
                <Icon name="check" size={14} class="text-emerald-500 shrink-0" strokeWidth={2.5} />
                {item}
              </div>
            ))}
          </div>
        </aside>

        <!-- Multi-step form -->
        <div data-reveal data-delay="2">

          <!-- Step progress bar -->
          <div class="flex items-center mb-10" id="step-progress" aria-label="Formular-Fortschritt">
            {[
              { n: 1, label: 'Leistung' },
              { n: 2, label: 'Budget'   },
              { n: 3, label: 'Kontakt'  },
            ].map((s, i) => (
              <>
                <div class="step-node flex items-center gap-2.5" data-step-node={s.n}>
                  <div class="step-circle w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all duration-300">
                    <span class="step-num">{s.n}</span>
                    <svg class="step-check hidden w-4 h-4" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="step-label text-xs font-semibold hidden sm:block">{s.label}</span>
                </div>
                {i < 2 && <div class="step-connector flex-1 h-0.5 mx-3 rounded-full transition-all duration-500 bg-[#EBEBEF]" data-connector={s.n}></div>}
              </>
            ))}
          </div>

          <form id="project-form" novalidate>

            <!-- STEP 1: Service -->
            <div class="form-step" data-step="1">
              <div class="mb-7">
                <h2 class="font-bold text-[#0C0C0F] text-xl lg:text-2xl tracking-[-0.02em] mb-1.5">
                  Welche Leistung suchen Sie?
                </h2>
                <p class="text-[#88888F] text-sm">Wählen Sie den passenden Bereich für Ihr Vorhaben.</p>
              </div>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-7">
                {services.map(s => (
                  <label class="service-option cursor-pointer">
                    <input type="radio" name="service" value={s.value} class="sr-only" required />
                    <div class="svc-card h-full rounded-2xl border-2 border-[#EBEBEF] p-4 flex flex-col gap-3 transition-all duration-150 hover:border-[#D4D4D9] hover:shadow-sm">
                      <div class="svc-icon w-9 h-9 rounded-xl bg-[#F5F5F8] flex items-center justify-center transition-all duration-150">
                        <Icon name={s.iconName} size={16} strokeWidth={1.75} class="transition-colors" />
                      </div>
                      <div>
                        <div class="font-semibold text-[#0C0C0F] text-[13px] leading-tight mb-0.5">{s.label}</div>
                        <div class="text-[11px] text-[#AEAEB5] leading-snug">{s.desc}</div>
                      </div>
                    </div>
                  </label>
                ))}
              </div>
              <div class="flex flex-col gap-3">
                <button type="button" class="btn btn-primary w-full justify-center py-3.5 text-[15px] next-btn">
                  Weiter
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <p class="text-center text-[11px] text-[#D4D4D9]">Schritt 1 von 3</p>
              </div>
            </div>

            <!-- STEP 2: Budget + Timeline -->
            <div class="form-step hidden" data-step="2">
              <div class="mb-7">
                <h2 class="font-bold text-[#0C0C0F] text-xl lg:text-2xl tracking-[-0.02em] mb-1.5">Budget & Zeitplan</h2>
                <p class="text-[#88888F] text-sm">Hilft uns, ein passendes Konzept vorzubereiten. Keine Pflichtangabe.</p>
              </div>
              <div class="mb-7">
                <p class="text-[11px] font-semibold text-[#62626E] uppercase tracking-[0.12em] mb-3">Ihr Budget</p>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5">
                  {budgets.map(b => (
                    <label class="budget-option cursor-pointer">
                      <input type="radio" name="budget" value={b.value} class="sr-only" />
                      <div class="pill-card rounded-xl border-2 border-[#EBEBEF] px-3.5 py-3 text-center text-[13px] font-medium text-[#62626E] transition-all duration-150 hover:border-[#D4D4D9] hover:text-[#0C0C0F]">
                        {b.label}
                      </div>
                    </label>
                  ))}
                </div>
              </div>
              <div class="mb-8">
                <p class="text-[11px] font-semibold text-[#62626E] uppercase tracking-[0.12em] mb-3">Wann soll's starten?</p>
                <div class="grid grid-cols-2 gap-2.5">
                  {timelines.map(t => (
                    <label class="timeline-option cursor-pointer">
                      <input type="radio" name="timeline" value={t.value} class="sr-only" />
                      <div class="pill-card rounded-xl border-2 border-[#EBEBEF] px-3.5 py-3 text-center text-[13px] font-medium text-[#62626E] transition-all duration-150 hover:border-[#D4D4D9] hover:text-[#0C0C0F]">
                        {t.label}
                      </div>
                    </label>
                  ))}
                </div>
              </div>
              <div class="flex gap-3">
                <button type="button" class="btn btn-outline py-3.5 px-5 prev-btn">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M13 7H1M6 2L1 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Zurück
                </button>
                <button type="button" class="btn btn-primary flex-1 justify-center py-3.5 text-[15px] next-btn">
                  Weiter
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
              <p class="text-center text-[11px] text-[#D4D4D9] mt-3">Schritt 2 von 3</p>
            </div>

            <!-- STEP 3: Contact details -->
            <div class="form-step hidden" data-step="3">
              <div class="mb-7">
                <h2 class="font-bold text-[#0C0C0F] text-xl lg:text-2xl tracking-[-0.02em] mb-1.5">Ihre Kontaktdaten</h2>
                <p class="text-[#88888F] text-sm">Fast geschafft – wir melden uns innerhalb von 24 Stunden.</p>
              </div>
              <div class="space-y-3 mb-5">
                <div class="grid grid-cols-2 gap-3">
                  <div class="float-group">
                    <input type="text" id="vorname" name="vorname" required placeholder=" " class="float-input" autocomplete="given-name" />
                    <label for="vorname" class="float-label">Vorname *</label>
                  </div>
                  <div class="float-group">
                    <input type="text" id="nachname" name="nachname" required placeholder=" " class="float-input" autocomplete="family-name" />
                    <label for="nachname" class="float-label">Nachname *</label>
                  </div>
                </div>
                <div class="float-group">
                  <input type="email" id="email" name="email" required placeholder=" " class="float-input" autocomplete="email" />
                  <label for="email" class="float-label">E-Mail-Adresse *</label>
                </div>
                <div class="float-group">
                  <input type="tel" id="telefon" name="telefon" placeholder=" " class="float-input" autocomplete="tel" />
                  <label for="telefon" class="float-label">Telefon (optional)</label>
                </div>
                <div class="float-group float-group--textarea">
                  <textarea id="nachricht" name="nachricht" required placeholder=" " rows="5" maxlength="500" class="float-input float-textarea"></textarea>
                  <label for="nachricht" class="float-label float-label--textarea">Projektbeschreibung *</label>
                  <div id="char-counter" class="absolute bottom-3 right-3.5 text-[10.5px] text-[#D4D4D9] pointer-events-none tabular-nums">0 / 500</div>
                </div>
              </div>
              <div class="flex items-start gap-3 mb-6">
                <div class="custom-cb-wrapper mt-0.5 shrink-0 cursor-pointer" id="cb-wrapper">
                  <input type="checkbox" id="datenschutz" name="datenschutz" required class="sr-only" />
                  <div class="cb-box w-5 h-5 rounded-md border-2 border-[#D4D4D9] flex items-center justify-center transition-all duration-150">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="cb-check opacity-0 scale-75 transition-all duration-150">
                      <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
                <label for="datenschutz" class="text-xs text-[#88888F] leading-relaxed cursor-pointer">
                  Ich habe die <a href="/datenschutz" class="text-accent-600 hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. *
                </label>
              </div>
              <div class="flex gap-3">
                <button type="button" class="btn btn-outline py-3.5 px-5 prev-btn">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M13 7H1M6 2L1 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Zurück
                </button>
                <button type="submit" class="btn btn-primary flex-1 justify-center py-3.5 text-[15px]" id="submit-btn">
                  Anfrage absenden
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
              <p id="form-error" class="hidden mt-3 text-sm text-red-600 text-center leading-relaxed"></p>
              <p class="text-center text-[11px] text-[#D4D4D9] mt-3">Schritt 3 von 3</p>
            </div>

          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }
  .form-step { animation: stepEnter 0.35s cubic-bezier(0.22, 1, 0.36, 1) both; }
  @keyframes stepEnter {
    from { opacity: 0; transform: translateX(28px); }
    to   { opacity: 1; transform: none; }
  }
  .form-step.step-back { animation: stepEnterBack 0.35s cubic-bezier(0.22, 1, 0.36, 1) both; }
  @keyframes stepEnterBack {
    from { opacity: 0; transform: translateX(-28px); }
    to   { opacity: 1; transform: none; }
  }
  .step-circle { background: white; border-color: #EBEBEF; color: #AEAEB5; }
  .step-label  { color: #AEAEB5; }
  [data-step-state="active"] .step-circle { background: #0C0C0F; border-color: #0C0C0F; color: white; }
  [data-step-state="active"] .step-label  { color: #0C0C0F; }
  [data-step-state="done"] .step-circle   { background: #0284C7; border-color: #0284C7; color: white; }
  [data-step-state="done"] .step-num      { display: none; }
  [data-step-state="done"] .step-check    { display: block !important; }
  [data-step-state="done"] .step-label    { color: #0284C7; }
  .service-option input:checked ~ .svc-card { border-color: #0284C7; background: #F0F9FF; box-shadow: 0 0 0 1px #0284C7; }
  .service-option input:checked ~ .svc-card .svc-icon { background: #0284C7; color: white; }
  .budget-option input:checked ~ .pill-card,
  .timeline-option input:checked ~ .pill-card { border-color: #0284C7; background: #F0F9FF; color: #0369A1; font-weight: 600; box-shadow: 0 0 0 1px #0284C7; }
  .float-group { position: relative; }
  .float-input { width: 100%; padding: 1.5rem 1rem 0.625rem; background: #FAFAF8; border: 1.5px solid #EBEBEF; border-radius: 0.875rem; font-size: 0.875rem; color: #0C0C0F; outline: none; transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease; font-family: inherit; }
  .float-input:hover  { border-color: #D4D4D9; }
  .float-input:focus  { border-color: #0284C7; background: white; box-shadow: 0 0 0 3px rgba(56,189,248,0.15); }
  .float-textarea     { resize: none; padding-bottom: 2rem; }
  .float-label        { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); font-size: 0.875rem; color: #AEAEB5; pointer-events: none; transition: top 0.15s ease, font-size 0.15s ease, color 0.15s ease, transform 0.15s ease; white-space: nowrap; transform-origin: left center; }
  .float-label--textarea { top: 1rem; transform: none; }
  .float-input:focus ~ .float-label,
  .float-input:not(:placeholder-shown) ~ .float-label { top: 0.45rem; font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.03em; color: #0284C7; transform: none; }
  .float-textarea:focus ~ .float-label--textarea,
  .float-textarea:not(:placeholder-shown) ~ .float-label--textarea { top: 0.35rem; font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.03em; color: #0284C7; }
  .custom-cb-wrapper:hover .cb-box { border-color: #AEAEB5; }
  .cb-box.is-checked { background: #0284C7; border-color: #0284C7; }
  .cb-box.is-checked .cb-check { opacity: 1 !important; transform: scale(1) !important; }
  #submit-btn.loading { opacity: 0.7; pointer-events: none; }
  #submit-btn.loading::after { content: ''; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.35); border-top-color: white; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 0.25rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes shake { 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-4px)} 40%,80%{transform:translateX(4px)} }
  .shake { animation: shake 0.4s ease; }
</style>

<script>
  let currentStep = 1;
  const TOTAL = 3;

  function getStepEl(n: number) { return document.querySelector<HTMLElement>(`.form-step[data-step="${n}"]`); }
  function getNode(n: number)   { return document.querySelector<HTMLElement>(`[data-step-node="${n}"]`); }
  function getConnector(n: number) { return document.querySelector<HTMLElement>(`[data-connector="${n}"]`); }

  function updateProgress() {
    for (let i = 1; i <= TOTAL; i++) {
      const node = getNode(i);
      if (!node) continue;
      if (i < currentStep)      node.dataset.stepState = 'done';
      else if (i === currentStep) node.dataset.stepState = 'active';
      else delete node.dataset.stepState;
    }
    for (let i = 1; i < TOTAL; i++) {
      const line = getConnector(i);
      if (line) line.style.background = i < currentStep ? '#0284C7' : '#EBEBEF';
    }
  }

  function goToStep(next: number, direction: 'forward' | 'back' = 'forward') {
    const current = getStepEl(currentStep);
    const target  = getStepEl(next);
    if (!target) return;
    current?.classList.add('hidden');
    target.classList.remove('hidden', 'step-back');
    if (direction === 'back') target.classList.add('step-back');
    currentStep = next;
    updateProgress();
    document.getElementById('project-form')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function validateStep(step: number): boolean {
    if (step === 1) {
      const selected = document.querySelector<HTMLInputElement>('input[name="service"]:checked');
      if (!selected) {
        document.querySelectorAll('.svc-card').forEach(c => {
          (c as HTMLElement).style.borderColor = '#FDA4AF';
          setTimeout(() => ((c as HTMLElement).style.borderColor = ''), 1200);
        });
        return false;
      }
    }
    if (step === 3) {
      const form = document.getElementById('project-form') as HTMLFormElement;
      return form.checkValidity();
    }
    return true;
  }

  document.querySelectorAll('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!validateStep(currentStep)) return;
      if (currentStep < TOTAL) goToStep(currentStep + 1, 'forward');
    });
  });

  document.querySelectorAll('.prev-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) goToStep(currentStep - 1, 'back');
    });
  });

  document.querySelectorAll('.service-option input').forEach(input => {
    input.addEventListener('change', () => {
      setTimeout(() => {
        if (currentStep === 1 && validateStep(1)) goToStep(2, 'forward');
      }, 260);
    });
  });

  const cbWrapper = document.getElementById('cb-wrapper');
  const cbInput   = document.getElementById('datenschutz') as HTMLInputElement | null;
  const cbBox     = cbWrapper?.querySelector('.cb-box');
  cbWrapper?.addEventListener('click', () => {
    if (!cbInput) return;
    cbInput.checked = !cbInput.checked;
    cbBox?.classList.toggle('is-checked', cbInput.checked);
  });
  document.querySelector('label[for="datenschutz"]')?.addEventListener('click', (e) => {
    e.preventDefault();
    cbWrapper?.click();
  });

  const textarea = document.getElementById('nachricht') as HTMLTextAreaElement | null;
  const counter  = document.getElementById('char-counter');
  textarea?.addEventListener('input', () => {
    const len = textarea.value.length;
    if (counter) {
      counter.textContent = `${len} / 500`;
      counter.style.color = len > 480 ? '#DC2626' : len > 440 ? '#0284C7' : '#D4D4D9';
    }
  });

  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  document.getElementById('project-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const form = e.currentTarget as HTMLFormElement;

    const cbInp = document.getElementById('datenschutz') as HTMLInputElement | null;
    const cbBoxEl = document.querySelector<HTMLElement>('#cb-wrapper .cb-box');

    if (!cbInp?.checked) {
      cbBoxEl?.parentElement?.classList.add('shake');
      setTimeout(() => cbBoxEl?.parentElement?.classList.remove('shake'), 500);
      return;
    }

    const fd = new FormData(form);
    const data: Record<string, string> = {};
    fd.forEach((v, k) => { data[k] = v.toString(); });
    data['datenschutz'] = 'true';

    submitBtn?.classList.add('loading');

    try {
      const res  = await fetch('/api/projekt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (res.ok && json.ok) {
        window.location.href = '/danke';
      } else {
        throw new Error(json.error ?? 'Unbekannter Fehler');
      }
    } catch (err) {
      submitBtn?.classList.remove('loading');
      const errMsg = document.getElementById('form-error');
      if (errMsg) {
        const fallback =
          'Es ist ein Fehler aufgetreten. Bitte versuche es erneut oder schreibe uns direkt an hallo@zulastudios.de.';
        errMsg.textContent = err instanceof Error && err.message ? err.message : fallback;
        errMsg.classList.remove('hidden');
      }
    }
  });

  updateProgress();
</script>
