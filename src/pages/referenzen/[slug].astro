---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';
import { projekte, serviceBadge } from '@/data/projekte';

export function getStaticPaths() {
  return projekte.map(p => ({ params: { slug: p.slug }, props: { projekt: p } }));
}

const { projekt: p } = Astro.props;

// Next project (wrap around)
const currentIndex = projekte.findIndex(x => x.slug === p.slug);
const nextProjekt = projekte[(currentIndex + 1) % projekte.length];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  name: `Case Study: ${p.client}`,
  description: p.tagline,
  url: `${SITE.url}/referenzen/${p.slug}`,
  author: { '@type': 'Organization', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
};

const badge = serviceBadge[p.serviceType];
---

<BaseLayout
  title={`${p.client} – Case Study`}
  description={p.tagline}
  schema={schema}
  darkHero={true}
  breadcrumbs={[
    { name: 'Startseite', url: '/' },
    { name: 'Referenzen', url: '/referenzen' },
    { name: p.client, url: `/referenzen/${p.slug}` },
  ]}
>

  <!-- ═══════════════════════════════════════
       HERO — dark, full bleed
  ═══════════════════════════════════════ -->
  <section
    class="relative min-h-[60vh] flex flex-col justify-end pb-16 pt-24 overflow-hidden"
    style={`background: ${p.cardBg};`}
  >
    <!-- Monogram background -->
    <div
      class="absolute bottom-0 right-0 font-bold leading-none select-none pointer-events-none"
      style={`font-size: clamp(14rem, 30vw, 26rem); letter-spacing: -0.05em; color: ${p.cardAccent}; opacity: 0.08; line-height: 0.85; transform: translate(5%, 5%);`}
      aria-hidden="true"
    >
      {p.clientKurz}
    </div>

    <!-- Subtle grid -->
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-12 flex-wrap">
        <a href="/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <a href="/referenzen" class="hover:text-white transition-colors">Referenzen</a>
        <span>/</span>
        <span class="text-white/60">{p.client}</span>
      </nav>

      <div class="max-w-3xl">
        <!-- Service badge -->
        <div
          class="inline-flex items-center gap-2 border rounded-full px-3.5 py-1.5 text-[11px] font-semibold mb-6"
          style={`border-color: ${p.cardAccent}30; color: ${p.cardAccent};`}
        >
          <span class="w-1.5 h-1.5 rounded-full" style={`background: ${p.cardAccent};`}></span>
          {p.service} · {p.industry}
        </div>

        <!-- Client & title -->
        <p class="text-white/40 text-sm font-medium mb-2">{p.client}</p>
        <h1
          class="font-bold text-white leading-[0.93] tracking-[-0.04em] mb-6"
          style="font-size: clamp(2rem, 5.5vw, 4.5rem); animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s both"
        >
          {p.tagline}
        </h1>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-white/35" style="animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.2s both">
          <span class="flex items-center gap-2">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="opacity-50">
              <rect x="1" y="2" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M1 6h12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M4 1v2M10 1v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            {p.jahr}
          </span>
          <span class="flex items-center gap-2">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="opacity-50">
              <path d="M7 1l1.8 3.6L13 5.4l-3 2.9.7 4.1L7 10.4l-3.7 2 .7-4.1-3-2.9 4.2-.8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            Zula Studios
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       METRICS BAND
  ═══════════════════════════════════════ -->
  <section class="bg-[#0C0C0F] border-b border-[#1C1C25]">
    <div class="container">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-[#1C1C25]">
        {p.metrics.map((m, i) => (
          <div class="px-6 lg:px-10 py-8" data-reveal data-delay={String(i + 1)}>
            <div class="font-bold text-white text-3xl lg:text-4xl tracking-[-0.04em] leading-none mb-2" style={`color: ${i === 0 ? p.cardAccent : 'white'};`}>
              {m.value}
            </div>
            <div class="text-[#44444F] text-xs font-medium">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CASE STUDY CONTENT
  ═══════════════════════════════════════ -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar (sticky on desktop) -->
        <aside class="lg:sticky lg:top-24 h-fit space-y-8">
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-3">Kunde</p>
            <p class="font-semibold text-[#0C0C0F] text-sm">{p.client}</p>
          </div>
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-3">Branche</p>
            <p class="font-semibold text-[#0C0C0F] text-sm">{p.industry}</p>
          </div>
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-3">Leistung</p>
            <p class="font-semibold text-[#0C0C0F] text-sm">{p.service}</p>
          </div>
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-3">Jahr</p>
            <p class="font-semibold text-[#0C0C0F] text-sm">{p.jahr}</p>
          </div>
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-3">Tags</p>
            <div class="flex flex-wrap gap-1.5">
              {p.tags.map(t => (
                <span class="text-[10.5px] font-medium bg-[#F5F5F8] text-[#62626E] px-2 py-0.5 rounded">{t}</span>
              ))}
            </div>
          </div>
        </aside>

        <!-- Main content -->
        <div class="space-y-16">

          <!-- Challenge -->
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-5 flex items-center gap-3">
              <span class="w-4 h-px bg-[#EBEBEF]"></span>
              Ausgangssituation
            </p>
            <h2 class="font-bold text-[#0C0C0F] text-2xl lg:text-3xl tracking-[-0.02em] mb-4">Die Herausforderung</h2>
            <p class="text-[#44444F] text-base lg:text-[17px] leading-relaxed">{p.challenge}</p>
          </div>

          <!-- Divider -->
          <div class="h-px bg-[#EBEBEF]"></div>

          <!-- Solution -->
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-5 flex items-center gap-3">
              <span class="w-4 h-px bg-[#EBEBEF]"></span>
              Umsetzung
            </p>
            <h2 class="font-bold text-[#0C0C0F] text-2xl lg:text-3xl tracking-[-0.02em] mb-4">Unsere Lösung</h2>
            <p class="text-[#44444F] text-base lg:text-[17px] leading-relaxed">{p.solution}</p>
          </div>

          <!-- Divider -->
          <div class="h-px bg-[#EBEBEF]"></div>

          <!-- Results -->
          <div data-reveal>
            <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-5 flex items-center gap-3">
              <span class="w-4 h-px bg-[#EBEBEF]"></span>
              Ergebnis
            </p>
            <h2 class="font-bold text-[#0C0C0F] text-2xl lg:text-3xl tracking-[-0.02em] mb-4">Was erreicht wurde</h2>
            <p class="text-[#44444F] text-base lg:text-[17px] leading-relaxed mb-8">{p.resultText}</p>

            <!-- Metrics in context -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
              {p.metrics.map((m, i) => (
                <div class="rounded-2xl p-5 border border-[#EBEBEF] bg-[#FAFAF8]" data-reveal data-delay={String(i + 1)}>
                  <div
                    class="font-bold text-2xl lg:text-3xl tracking-[-0.04em] leading-none mb-2"
                    style={`color: ${i === 0 ? p.cardAccent : '#0C0C0F'};`}
                  >
                    {m.value}
                  </div>
                  <div class="text-[#88888F] text-xs leading-tight">{m.label}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Testimonial -->
          {p.testimonial && (
            <div class="rounded-2xl bg-[#FAFAF8] border border-[#EBEBEF] p-8 lg:p-10" data-reveal>
              <!-- Large quote mark -->
              <svg width="32" height="24" viewBox="0 0 28 22" fill="none" class="mb-5">
                <path d="M0 22V13.2C0 5.6 4.2 1.4 12.6 0l1.4 2.8C9.8 3.8 7.7 5.6 7 8.4h5.6V22H0zm15.4 0V13.2C15.4 5.6 19.6 1.4 28 0l1.4 2.8C25.2 3.8 23.1 5.6 22.4 8.4H28V22H15.4z" fill="#EBEBEF"/>
              </svg>
              <blockquote class="text-[#44444F] text-base lg:text-lg leading-relaxed mb-6">
                {p.testimonial.quote}
              </blockquote>
              <footer class="flex items-center gap-3">
                <div
                  class="w-10 h-10 rounded-xl font-bold text-white text-sm flex items-center justify-center shrink-0"
                  style={`background: ${p.cardAccent};`}
                >
                  {p.testimonial.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
                </div>
                <div>
                  <div class="font-semibold text-[#0C0C0F] text-sm">{p.testimonial.name}</div>
                  <div class="text-[#AEAEB5] text-xs mt-0.5">{p.testimonial.role}</div>
                </div>
              </footer>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       NEXT PROJECT
  ═══════════════════════════════════════ -->
  <section class="bg-[#FAFAF8] border-t border-[#EBEBEF] py-12">
    <div class="container">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <p class="text-[10.5px] font-semibold tracking-[0.18em] uppercase text-[#AEAEB5] mb-1">Nächste Referenz</p>
          <p class="font-bold text-[#0C0C0F] text-lg tracking-[-0.01em]">{nextProjekt.client}</p>
          <p class="text-[#88888F] text-sm mt-0.5">{nextProjekt.service}</p>
        </div>
        <div class="flex gap-3">
          <a href="/referenzen" class="btn btn-outline text-sm py-2.5">
            ← Alle Referenzen
          </a>
          <a href={`/referenzen/${nextProjekt.slug}`} class="btn btn-primary text-sm py-2.5">
            Nächste Case Study
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA
  ═══════════════════════════════════════ -->
  <section class="bg-[#0C0C0F] py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 100%, rgba(56,189,248,0.16), transparent 55%);"></div>
    <div class="container relative z-10 text-center max-w-xl mx-auto" data-reveal>
      <h2 class="font-bold text-white tracking-[-0.03em] text-3xl mb-4">Ähnliche Ergebnisse für Ihr Business?</h2>
      <p class="text-[#62626E] mb-8">Starten Sie mit einem kostenlosen Erstgespräch.</p>
      <a href="/projekt-starten" class="btn bg-white text-[#0C0C0F] hover:bg-[#F5F5F8] py-3.5 px-8 text-[15px] rounded-xl font-semibold">
        Kostenloses Erstgespräch
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }
</style>
