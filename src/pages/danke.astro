---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vielen Dank für Ihre Anfrage"
  description="Wir haben Ihre Anfrage erhalten und melden uns innerhalb von 24 Stunden."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="w-20 h-20 rounded-full bg-accent-500/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-display font-extrabold text-3xl lg:text-4xl text-gray-900 mb-4">
        Vielen Dank!
      </h1>
      <p class="text-gray-500 text-lg mb-8 leading-relaxed">
        Wir haben Ihre Anfrage erhalten und melden uns innerhalb von <strong class="text-gray-900">24 Stunden</strong> bei Ihnen.
      </p>
      <a href="/" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition-all">
        Zurück zur Startseite
      </a>
    </div>
  </section>
</BaseLayout>
