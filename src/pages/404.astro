---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden"
  description="Die gesuchte Seite wurde nicht gefunden."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="font-display font-extrabold text-8xl text-brand-100 mb-4 select-none">404</div>
      <h1 class="font-display font-extrabold text-3xl text-gray-900 mb-4">
        Seite nicht gefunden
      </h1>
      <p class="text-gray-500 mb-8">
        Die gesuchte Seite existiert leider nicht (mehr). Vielleicht hilft Ihnen einer der folgenden Links weiter.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-xl hover:bg-brand-700 transition-colors">Startseite</a>
        <a href="/leistungen" class="bg-gray-100 text-gray-700 font-semibold px-5 py-2.5 rounded-xl hover:bg-gray-200 transition-colors">Leistungen</a>
        <a href="/blog" class="bg-gray-100 text-gray-700 font-semibold px-5 py-2.5 rounded-xl hover:bg-gray-200 transition-colors">Blog</a>
        <a href="/kontakt" class="bg-gray-100 text-gray-700 font-semibold px-5 py-2.5 rounded-xl hover:bg-gray-200 transition-colors">Kontakt</a>
      </div>
    </div>
  </section>
</BaseLayout>
