---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';
import Icon from '@/components/Icon.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Shopify Shop erstellen',
  description: 'Professionelle Shopify Shop Entwicklung – von der Konzeption bis zum Launch. Custom Themes, Performance-Optimierung, SEO-Setup.',
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  serviceType: 'Shopify Development',
  areaServed: { '@type': 'Country', name: 'Germany' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Wie lange dauert die Entwicklung?', acceptedAnswer: { '@type': 'Answer', text: 'Einfache Shops: 2–4 Wochen. Individuelle Custom-Shops: 2–4 Monate. Den genauen Zeitplan legen wir nach dem Briefing fest.' } },
    { '@type': 'Question', name: 'Welche Shopify-Version brauche ich?', acceptedAnswer: { '@type': 'Answer', text: 'Das hängt von Umsatz und Anforderungen ab. Wir beraten Sie neutral und empfehlen die optimale Lösung für Ihr Business.' } },
  ],
};
---

<BaseLayout
  title="Shopify Shop erstellen lassen – Professionell & Conversion-optimiert"
  description="Professionellen Shopify Shop erstellen lassen: Custom Theme, SEO-Setup, Performance-Optimierung. 10+ Projekte. Jetzt kostenloses Angebot anfragen."
  schema={[serviceSchema, faqSchema]}
  darkHero={true}
  breadcrumbs={[
    { name: 'Startseite', url: '/' },
    { name: 'Leistungen', url: '/leistungen' },
    { name: 'Shopify Shop erstellen', url: '/leistungen/shopify-shop-erstellen' },
  ]}
>

  <!-- HERO -->
  <section class="bg-[#0C0C0F] pb-20 pt-16 lg:pb-28 lg:pt-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px]" style="background: radial-gradient(circle at 80% 20%, rgba(56,189,248,0.2), transparent 60%);"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[#9898A0] mb-10 flex-wrap" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <a href="/leistungen" class="hover:text-white transition-colors">Leistungen</a>
        <span>/</span>
        <span class="text-[#AEAEB5]">Shopify Shop erstellen</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 items-start">
        <div>
          <div class="inline-flex items-center gap-2 border border-[#1C1C25] rounded-full px-4 py-1.5 text-[11.5px] text-[#9898A0] font-medium mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[#38BDF8]"></span>
            Shopify Shop Entwicklung
          </div>
          <h1
            class="font-bold text-white mb-5 tracking-[-0.04em] leading-[0.93]"
            style="font-size: clamp(2.75rem, 7vw, 6rem); animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s both"
          >
            Shopify Shops,<br/>
            <span class="font-light italic text-white/55">die wirklich</span><br/>
            verkaufen.
          </h1>
          <p class="text-[#AEAEB5] text-base lg:text-lg max-w-lg leading-relaxed mb-10" style="animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.2s both">
            Wir entwickeln performante, conversion-optimierte Shopify-Shops — vom ersten Gespräch bis zum erfolgreichen Launch.
          </p>
          <div class="flex flex-wrap gap-3" style="animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.3s both">
            <a href="/projekt-starten" class="btn bg-white text-[#0C0C0F] hover:bg-[#F5F5F8] py-3.5 px-7 text-[15px] rounded-xl font-semibold">
              Kostenloses Angebot
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/referenzen" class="btn btn-ghost py-3.5 px-7 text-[15px]">Referenzen ansehen</a>
          </div>
        </div>

        <!-- Trust signals panel -->
        <div class="hidden lg:block" style="animation: fadeUp 0.75s cubic-bezier(0.22,1,0.36,1) 0.25s both">
          <div class="border border-[#1C1C25] rounded-2xl overflow-hidden min-w-[200px]">
            {[
              'Shopify Partner',
              'Custom Development',
              'SEO-Optimierung',
              '60 Tage Support',
              'DSGVO-konform',
            ].map((text, i) => (
              <div class:list={["flex items-center gap-3 px-5 py-3.5 text-[13px] text-[#AEAEB5]", i < 4 ? "border-b border-[#1C1C25]" : ""]}>
                <Icon name="check" size={13} class="text-[#0284C7] shrink-0" strokeWidth={2.5} />
                {text}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-[#1C1C25]"></div>
  </section>

  <!-- WHY SHOPIFY — horizontal scroll features -->
  <section class="py-20 lg:py-24 bg-white">
    <div class="container">
      <div class="mb-12" data-reveal>
        <p class="label mb-3">Warum Shopify</p>
        <h2 class="font-bold text-[#0C0C0F] tracking-[-0.03em]" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.1;">Die führende E-Commerce Plattform</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { iconName: 'zap', title: 'Schnell & skalierbar', desc: 'Globales CDN inklusive — von 0 auf Millionen Bestellungen.' },
          { iconName: 'shield', title: 'Sicher & verlässlich', desc: '99,99% Uptime, PCI-DSS, kostenloses SSL, kein Hosting-Stress.' },
          { iconName: 'mobile', title: 'Mobile-first', desc: 'Alle Themes vollständig mobiloptimiert. Core Web Vitals included.' },
          { iconName: 'globe', title: 'International', desc: 'Multi-Sprache, Multi-Währung und lokale Zahlungsanbieter out of the box.' },
          { iconName: 'grid', title: '8.000+ Apps', desc: 'Der größte App Store im E-Commerce. Jede Integration verfügbar.' },
          { iconName: 'chart', title: 'Analytics', desc: 'GA4, GTM, Shopify Audiences — datengetriebenes Wachstum.' },
        ].map((item, i) => (
          <div class="p-6 bg-[#FAFAF8] rounded-2xl border border-[#EBEBEF] hover:bg-white hover:border-[#D4D4D9] transition-all" data-reveal data-delay={String((i % 3) + 1)}>
            <div class="w-9 h-9 rounded-xl bg-[#0C0C0F] text-white flex items-center justify-center mb-4">
              <Icon name={item.iconName} size={16} strokeWidth={1.75} />
            </div>
            <h3 class="font-semibold text-[#0C0C0F] text-[14.5px] mb-1.5">{item.title}</h3>
            <p class="text-[#88888F] text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="container max-w-2xl">
      <h2 class="font-bold text-[#0C0C0F] tracking-[-0.02em] text-2xl mb-8" data-reveal>Häufige Fragen</h2>
      <div class="space-y-2">
        {[
          { q: 'Wie lange dauert die Entwicklung?', a: 'Einfache Shops: 2–4 Wochen. Individuelle Custom-Shops: 2–4 Monate. Den Zeitplan legen wir nach dem Briefing fest.' },
          { q: 'Welche Shopify-Version brauche ich?', a: 'Das hängt von Umsatz und Anforderungen ab. Wir beraten Sie neutral und empfehlen die optimale Lösung für Ihr Business.' },
          { q: 'Kümmert ihr euch auch um den Content?', a: 'Auf Wunsch übernehmen wir das Einpflegen von Produkten, Texten und Bildern — oder wir schulen Ihr Team.' },
          { q: 'Wie läuft die Zusammenarbeit ab?', a: 'Nach dem Erstgespräch erhalten Sie ein individuelles Angebot. Danach folgen Konzeption, Entwicklung mit wöchentlichen Updates und der gemeinsame Launch.' },
        ].map(item => (
          <details class="group bg-[#FAFAF8] rounded-xl border border-[#EBEBEF] hover:border-[#D4D4D9] transition-colors" data-reveal>
            <summary class="flex items-center justify-between gap-4 px-5 py-4 font-semibold text-[#0C0C0F] text-[14.5px] cursor-pointer">
              {item.q}
              <span class="w-5 h-5 rounded-full border border-[#EBEBEF] flex items-center justify-center shrink-0 text-[#AEAEB5] group-open:rotate-45 transition-transform">
                <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M5 1v8M1 5h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </span>
            </summary>
            <div class="px-5 pb-4 text-[#62626E] text-sm leading-relaxed border-t border-[#EBEBEF] pt-3.5">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-[#0C0C0F] py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 120%, rgba(56,189,248,0.22), transparent 60%);"></div>
    <div class="container relative z-10 text-center max-w-xl mx-auto">
      <h2 class="font-bold text-white tracking-[-0.03em] text-3xl lg:text-4xl mb-4" data-reveal>Bereit für Ihren neuen Shopify Shop?</h2>
      <p class="text-[#9898A0] mb-8" data-reveal data-delay="1">Kostenloses Erstgespräch — kein Risiko, kein Verkaufsdruck.</p>
      <a href="/projekt-starten" class="btn bg-white text-[#0C0C0F] hover:bg-[#F5F5F8] py-3.5 px-8 text-[15px] rounded-xl font-semibold" data-reveal data-delay="2">
        Jetzt kostenlos anfragen
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <style>
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }
  </style>
</BaseLayout>
