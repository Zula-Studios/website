# SMTP für Formular-E-Mails (Nodemailer). Beispiele: Strato, All-Inkl, Google Workspace (SMTP),
# Microsoft 365, oder Transactional-Anbieter mit SMTP-Zugang.
# Lokal: diese Datei als .env kopieren. Production: Variablen z. B. in Vercel setzen.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Bei Port 465 oft true; bei 587 meist false (STARTTLS)
SMTP_SECURE=false
SMTP_USER=...
SMTP_PASS=...
# Absender (muss beim Provider erlaubt sein), z. B.:
SMTP_FROM=Zula Studios <noreply@zulastudios.de>
